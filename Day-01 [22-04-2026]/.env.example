# Busly Database Configuration
BUSLY_DB_CONNECTION=Host=localhost;Database=busly;Username=your_username;Password=your_password;

# JWT Security
BUSLY_JWT_SECRET=your_secure_random_secret_at_least_32_characters

# SMTP Configuration (Email)
BUSLY_SMTP_HOST=smtp.mailtrap.io
BUSLY_SMTP_PORT=587
BUSLY_SMTP_USERNAME=your_smtp_username
BUSLY_SMTP_PASSWORD=your_smtp_password
BUSLY_SMTP_FROM=noreply@busly.com
