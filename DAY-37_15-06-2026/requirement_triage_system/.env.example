# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template for the Requirement Triage System
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in every value below, then save. The .env file must NEVER be
#   committed to source control — add it to .gitignore immediately.
# ─────────────────────────────────────────────────────────────────────────────

# ── GroqCloud ─────────────────────────────────────────────────────────────────
# Obtain your key from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Gmail Sender Account ──────────────────────────────────────────────────────
# The Gmail address that will SEND the report email.
SENDER_EMAIL=youremail@gmail.com

# Google App Password (NOT your regular Gmail password).
# Prerequisites:
#   1. Enable 2-Step Verification on your Google account.
#   2. Visit https://myaccount.google.com/apppasswords
#   3. Generate a new App Password (select "Mail" + your device).
#   4. Copy the 16-character code shown (with or without spaces — both accepted).
#
# Example format (spaces are stripped automatically by the loader):
#   GMAIL_APP_PASSWORD=abcd efgh ijkl mnop
GMAIL_APP_PASSWORD=abcd efgh ijkl mnop

# ── Report Recipient ──────────────────────────────────────────────────────────
# The email address that will RECEIVE the triage report.
RECEIVER_EMAIL=client-or-team@example.com

# ── Email Servers Configuration ─────────────────────────────────────────────
# These defaults work for Gmail. Only change them if you are switching providers.
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
